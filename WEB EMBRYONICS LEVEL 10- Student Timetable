<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>School Timetable</title>
</head>
<body>
    <h1>School Timetable</h1>

    <hr>

    <table border="1"><!--the border font is showing red 
        bcz this property is deprecated from html5 
        we use css but for html project we will use this for 
        temporary basis-->
    
        <thead>
            <tr>
                <th>Day</th>
                <th>Period 1</th>
                <th>Period 2</th>
                <th>Period 3</th>
                <th>Period 4</th>
                <th>Period 5</th>
                <th>Period 6</th>
            </tr>

            <tbody>
                <tr>
                    <td>Monday</td>
                    <td>Maths</td>
                    <td>Science</td>
                    <td>English</td>
                    <td>History</td>
                    <td>PE</td>
                    <td>Art</td>
                </tr>

                <tr>
                    <td>Tuesday</td>
                    <td>English</td>
                    <td>Maths</td>
                    <td>Science</td>
                    <td>Geography</td>
                    <td>Music</td>
                    <td>Computer</td>
                </tr>

                <tr>
                    <td>Wednesday</td>
                    <td colspan="2">Lab(Science)</td>
                    <td>Maths</td>
                    <td>English</td>
                    <td>History</td>
                    <td>PE</td>
                
                </tr>

                <tr>
                    <td>Thursday</td>
                    <td>Computer</td>
                    <td>Maths</td>
                    <td>Science</td>
                    <td>English</td>
                    <td>Art</td>
                    <td>Music</td>
                    
                </tr>

                <tr>
                    <td>Friday</td>
                    <td>History</td>
                    <td>Maths</td>
                    <td>English</td>
                    <td>Science</td>
                    <td>PE</td>
                    <td>Geography</td>
                    
                </tr>

            </tbody>
        </thead>

    </table>
</body>
</html>
